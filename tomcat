#!/bin/bash

set -Ee

TOMCAT_DIR="/opt/tomcat"
SERVICE_FILE="/etc/systemd/system/tomcat.service"
SERVER_XML="$TOMCAT_DIR/conf/server.xml"
WEBAPPS_DIR="$TOMCAT_DIR/webapps"
TOMCAT_MAJOR="11"
TOMCAT_MIRROR_BASE="https://dlcdn.apache.org/tomcat/tomcat-${TOMCAT_MAJOR}"
TOMCAT_ARCHIVE_BASE="https://archive.apache.org/dist/tomcat/tomcat-${TOMCAT_MAJOR}"
TOMCAT_URL="${TOMCAT_URL:-}"

trap 'echo "❌ Error on line $LINENO while running: $BASH_COMMAND (exit code: $?)" >&2' ERR

run_step() {
    "$@"
}

resolve_tomcat_url() {
    local latest_mirror_version=""
    local latest_archive_version=""
    local candidate=""

    if [ -n "$TOMCAT_URL" ]; then
        echo "ℹ️ Using TOMCAT_URL from environment: $TOMCAT_URL"
        return 0
    fi

    echo "🔎 Detecting latest Tomcat ${TOMCAT_MAJOR}.x release..."
    latest_mirror_version=$(wget -qO- "${TOMCAT_MIRROR_BASE}/" \
        | grep -oE "v${TOMCAT_MAJOR}\\.[0-9]+\\.[0-9]+/" \
        | tr -d '/' \
        | sed 's/^v//' \
        | sort -V \
        | tail -n1 || true)

    if [ -n "$latest_mirror_version" ]; then
        candidate="${TOMCAT_MIRROR_BASE}/v${latest_mirror_version}/bin/apache-tomcat-${latest_mirror_version}.tar.gz"
        if wget --spider -q "$candidate"; then
            TOMCAT_URL="$candidate"
            echo "✅ Selected mirror release: ${latest_mirror_version}"
            return 0
        fi
    fi

    latest_archive_version=$(wget -qO- "${TOMCAT_ARCHIVE_BASE}/" \
        | grep -oE "v${TOMCAT_MAJOR}\\.[0-9]+\\.[0-9]+/" \
        | tr -d '/' \
        | sed 's/^v//' \
        | sort -V \
        | tail -n1 || true)

    if [ -n "$latest_archive_version" ]; then
        candidate="${TOMCAT_ARCHIVE_BASE}/v${latest_archive_version}/bin/apache-tomcat-${latest_archive_version}.tar.gz"
        if wget --spider -q "$candidate"; then
            TOMCAT_URL="$candidate"
            echo "✅ Selected archive release: ${latest_archive_version}"
            return 0
        fi
    fi

    echo "❌ Unable to resolve a valid Tomcat ${TOMCAT_MAJOR}.x tarball URL." >&2
    echo "   Set TOMCAT_URL manually and rerun, for example:" >&2
    echo "   TOMCAT_URL='https://archive.apache.org/dist/tomcat/tomcat-${TOMCAT_MAJOR}/v${TOMCAT_MAJOR}.x.y/bin/apache-tomcat-${TOMCAT_MAJOR}.x.y.tar.gz' bash tomcat" >&2
    exit 1
}

as_root() {
    if [ "$EUID" -eq 0 ]; then
        "$@"
    elif command -v sudo >/dev/null 2>&1; then
        sudo "$@"
    else
        echo "❌ This script needs root privileges. Re-run as root or install sudo." >&2
        exit 1
    fi
}

is_tomcat_installed() {
    [ -d "$TOMCAT_DIR" ] && [ -f "$SERVER_XML" ]
}

install_tomcat() {
    echo "🚀 Installing Tomcat..."

    if ! command -v systemctl >/dev/null 2>&1; then
        echo "❌ systemctl not found. Tomcat service setup requires systemd." >&2
        exit 1
    fi

    run_step as_root apt-get update
    run_step as_root env DEBIAN_FRONTEND=noninteractive apt-get install -y openjdk-17-jdk wget tar

    run_step as_root groupadd -f tomcat
    if ! id -u tomcat &>/dev/null; then
        run_step as_root useradd -s /bin/false -g tomcat -d "$TOMCAT_DIR" tomcat
    fi

    resolve_tomcat_url
    echo "📦 Tomcat source: $TOMCAT_URL"
    run_step wget -O /tmp/tomcat.tar.gz "$TOMCAT_URL"

    run_step as_root mkdir -p "$TOMCAT_DIR"
    run_step as_root tar -xzf /tmp/tomcat.tar.gz -C "$TOMCAT_DIR" --strip-components=1
    run_step rm -f /tmp/tomcat.tar.gz

    run_step as_root chown -R tomcat:tomcat "$TOMCAT_DIR"
    run_step as_root chmod -R g+r "$TOMCAT_DIR/conf"
    run_step as_root chmod g+x "$TOMCAT_DIR/conf"

    JAVA_HOME_PATH=$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")

    as_root tee "$SERVICE_FILE" >/dev/null <<EOF_SERVICE
[Unit]
Description=Tomcat
After=network.target

[Service]
Type=forking
User=tomcat
Group=tomcat

Environment="JAVA_HOME=$JAVA_HOME_PATH"
Environment="CATALINA_BASE=$TOMCAT_DIR"
Environment="CATALINA_HOME=$TOMCAT_DIR"
Environment="CATALINA_PID=$TOMCAT_DIR/temp/tomcat.pid"
Environment="CATALINA_OPTS=-Xms512M -Xmx1024M -server -XX:+UseParallelGC"

ExecStart=$TOMCAT_DIR/bin/startup.sh
ExecStop=$TOMCAT_DIR/bin/shutdown.sh

Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF_SERVICE

    run_step as_root systemctl daemon-reload
    run_step as_root systemctl enable tomcat
    run_step as_root systemctl start tomcat

    if ! as_root systemctl is-active --quiet tomcat; then
        echo "❌ Tomcat failed to start. Showing recent service logs:"
        as_root systemctl --no-pager -l status tomcat || true
        exit 1
    fi

    echo "✅ Tomcat installed and running"
}

uninstall_tomcat() {
    echo "🧹 Uninstalling Tomcat..."

    as_root systemctl stop tomcat 2>/dev/null || true
    as_root systemctl disable tomcat 2>/dev/null || true

    as_root rm -f "$SERVICE_FILE"
    as_root rm -rf "$TOMCAT_DIR"

    as_root userdel tomcat 2>/dev/null || true
    as_root groupdel tomcat 2>/dev/null || true

    as_root systemctl daemon-reload

    echo "✅ Tomcat removed"
}

block_public_access() {
    if ! is_tomcat_installed; then
        echo "🌱 Tomcat environment not detected. Nothing to restrict yet."
        exit 0
    fi

    echo "🔒 Binding Tomcat to 127.0.0.1..."

    as_root systemctl stop tomcat

    if grep -q 'address="127.0.0.1"' "$SERVER_XML"; then
        echo "ℹ️ Already restricted to localhost"
    else
        as_root sed -i 's/<Connector port="8080"/<Connector address="127.0.0.1" port="8080"/' "$SERVER_XML"
        echo "✅ Updated connector"
    fi

    as_root systemctl start tomcat
}

clean_webapps() {
    if ! is_tomcat_installed; then
        echo "🌱 Tomcat not found. No webapps to clean."
        exit 0
    fi

    if [ ! -d "$WEBAPPS_DIR" ]; then
        echo "📂 webapps directory not present"
        exit 0
    fi

    echo "🧹 Cleaning webapps..."
    as_root rm -rf "${WEBAPPS_DIR:?}"/*
    echo "✅ webapps cleaned"
}

echo "=============================="
echo " Tomcat Management Script"
echo "=============================="
echo "1) Install Tomcat"
echo "2) Uninstall Tomcat"
echo "3) Block public access (127.0.0.1)"
echo "4) Clean webapps (/webapps/*)"
echo "=============================="

read -p "Select option [1-4]: " choice

case $choice in
    1) install_tomcat ;;
    2) uninstall_tomcat ;;
    3) block_public_access ;;
    4) clean_webapps ;;
    *) echo "❌ Invalid option"; exit 1 ;;
esac
