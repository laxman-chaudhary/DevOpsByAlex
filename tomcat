#!/bin/bash

set -e

TOMCAT_DIR="/opt/tomcat"
SERVICE_FILE="/etc/systemd/system/tomcat.service"
SERVER_XML="$TOMCAT_DIR/conf/server.xml"
WEBAPPS_DIR="$TOMCAT_DIR/webapps"
TOMCAT_URL="https://dlcdn.apache.org/tomcat/tomcat-11/v11.0.1/bin/apache-tomcat-11.0.1.tar.gz"

is_tomcat_installed() {
    [ -d "$TOMCAT_DIR" ] && [ -f "$SERVER_XML" ]
}

install_tomcat() {
    echo "🚀 Installing Tomcat..."

    sudo apt-get update -qq >/dev/null
    sudo DEBIAN_FRONTEND=noninteractive apt-get install -y -qq openjdk-17-jdk wget tar >/dev/null

    sudo groupadd -f tomcat
    id -u tomcat &>/dev/null || sudo useradd -s /bin/false -g tomcat -d "$TOMCAT_DIR" tomcat

    wget -q -O /tmp/tomcat.tar.gz "$TOMCAT_URL"

    sudo mkdir -p "$TOMCAT_DIR"
    sudo tar -xzf /tmp/tomcat.tar.gz -C "$TOMCAT_DIR" --strip-components=1
    rm -f /tmp/tomcat.tar.gz

    sudo chown -R tomcat:tomcat "$TOMCAT_DIR"
    sudo chmod -R g+r "$TOMCAT_DIR/conf"
    sudo chmod g+x "$TOMCAT_DIR/conf"

    JAVA_HOME_PATH=$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")

    sudo tee "$SERVICE_FILE" >/dev/null <<EOF_SERVICE
[Unit]
Description=Tomcat
After=network.target

[Service]
Type=forking
User=tomcat
Group=tomcat

Environment="JAVA_HOME=$JAVA_HOME_PATH"
Environment="CATALINA_BASE=$TOMCAT_DIR"
Environment="CATALINA_HOME=$TOMCAT_DIR"
Environment="CATALINA_PID=$TOMCAT_DIR/temp/tomcat.pid"
Environment="CATALINA_OPTS=-Xms512M -Xmx1024M -server -XX:+UseParallelGC"

ExecStart=$TOMCAT_DIR/bin/startup.sh
ExecStop=$TOMCAT_DIR/bin/shutdown.sh

Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF_SERVICE

    sudo systemctl daemon-reload
    sudo systemctl enable tomcat >/dev/null
    sudo systemctl start tomcat

    if ! sudo systemctl is-active --quiet tomcat; then
        echo "❌ Tomcat failed to start. Showing recent service logs:"
        sudo systemctl --no-pager -l status tomcat || true
        exit 1
    fi

    echo "✅ Tomcat installed and running"
}

uninstall_tomcat() {
    echo "🧹 Uninstalling Tomcat..."

    sudo systemctl stop tomcat 2>/dev/null || true
    sudo systemctl disable tomcat 2>/dev/null || true

    sudo rm -f "$SERVICE_FILE"
    sudo rm -rf "$TOMCAT_DIR"

    sudo userdel tomcat 2>/dev/null || true
    sudo groupdel tomcat 2>/dev/null || true

    sudo systemctl daemon-reload

    echo "✅ Tomcat removed"
}

block_public_access() {
    if ! is_tomcat_installed; then
        echo "🌱 Tomcat environment not detected. Nothing to restrict yet."
        exit 0
    fi

    echo "🔒 Binding Tomcat to 127.0.0.1..."

    sudo systemctl stop tomcat

    if grep -q 'address="127.0.0.1"' "$SERVER_XML"; then
        echo "ℹ️ Already restricted to localhost"
    else
        sudo sed -i 's/<Connector port="8080"/<Connector address="127.0.0.1" port="8080"/' "$SERVER_XML"
        echo "✅ Updated connector"
    fi

    sudo systemctl start tomcat
}

clean_webapps() {
    if ! is_tomcat_installed; then
        echo "🌱 Tomcat not found. No webapps to clean."
        exit 0
    fi

    if [ ! -d "$WEBAPPS_DIR" ]; then
        echo "📂 webapps directory not present"
        exit 0
    fi

    echo "🧹 Cleaning webapps..."
    sudo rm -rf "${WEBAPPS_DIR:?}"/*
    echo "✅ webapps cleaned"
}

echo "=============================="
echo " Tomcat Management Script"
echo "=============================="
echo "1) Install Tomcat"
echo "2) Uninstall Tomcat"
echo "3) Block public access (127.0.0.1)"
echo "4) Clean webapps (/webapps/*)"
echo "=============================="

read -p "Select option [1-4]: " choice

case $choice in
    1) install_tomcat ;;
    2) uninstall_tomcat ;;
    3) block_public_access ;;
    4) clean_webapps ;;
    *) echo "❌ Invalid option"; exit 1 ;;
esac
