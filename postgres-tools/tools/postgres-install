#!/bin/bash

# PostgreSQL Installation Script
# Usage: ./postgres-install 16,17,18
# or: ./postgres-install (will prompt for version selection)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to display usage
usage() {
    echo "Usage: $0 [versions]"
    echo "Examples:"
    echo "  $0 16           # Install PostgreSQL 16"
    echo "  $0 16,17,18     # Install PostgreSQL 16, 17, and 18"
    echo "  $0              # Interactive mode (select version)"
}

# Function to validate version
validate_version() {
    case "$1" in
        16|17|18)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# Get versions from arguments or prompt user
if [ $# -eq 0 ]; then
    echo -e "${YELLOW}=== PostgreSQL Version Selection ===${NC}"
    echo "Available versions:"
    echo "1) PostgreSQL 16"
    echo "2) PostgreSQL 17"
    echo "3) PostgreSQL 18"
    echo "4) All versions (16, 17, 18)"
    echo ""
    read -p "Select version(s) [1-4]: " choice
    
    case "$choice" in
        1) VERSIONS="16" ;;
        2) VERSIONS="17" ;;
        3) VERSIONS="18" ;;
        4) VERSIONS="16,17,18" ;;
        *)
            echo -e "${RED}Invalid selection${NC}"
            exit 1
            ;;
    esac
else
    VERSIONS="$1"
fi

# Validate all versions
IFS=',' read -ra VERSION_ARRAY <<< "$VERSIONS"
for version in "${VERSION_ARRAY[@]}"; do
    version=$(echo "$version" | xargs) # Trim whitespace
    if ! validate_version "$version"; then
        echo -e "${RED}Error: Invalid PostgreSQL version '$version'${NC}"
        echo "Supported versions: 16, 17, 18"
        exit 1
    fi
done

# Package Type Selection
echo ""
echo -e "${YELLOW}=== PostgreSQL Package Selection ===${NC}"
echo "1) Client only (psql, utilities)"
echo "2) Server only (PostgreSQL server)"
echo "3) Both (client + server)"
echo ""
read -p "Select package type [1-3]: " package_choice

case "$package_choice" in
    1) INSTALL_CLIENT=true; INSTALL_SERVER=false; PACKAGE_TYPE="Client" ;;
    2) INSTALL_CLIENT=false; INSTALL_SERVER=true; PACKAGE_TYPE="Server" ;;
    3) INSTALL_CLIENT=true; INSTALL_SERVER=true; PACKAGE_TYPE="Client + Server" ;;
    *)
        echo -e "${RED}Invalid selection${NC}"
        exit 1
        ;;
esac

echo -e "${GREEN}Installing PostgreSQL $PACKAGE_TYPE version(s): $VERSIONS${NC}"

# Update package list and install prerequisites
echo -e "${YELLOW}[1/3] Installing prerequisites...${NC}"
sudo apt install -y curl ca-certificates

# Setup PostgreSQL repository
echo -e "${YELLOW}[2/3] Setting up PostgreSQL repository...${NC}"
sudo install -d /usr/share/postgresql-common/pgdg
sudo curl -o /usr/share/postgresql-common/pgdg/apt.postgresql.org.asc --fail https://www.postgresql.org/media/keys/ACCC4CF8.asc
sudo sh -c 'echo "deb [signed-by=/usr/share/postgresql-common/pgdg/apt.postgresql.org.asc] https://apt.postgresql.org/pub/repos/apt $(lsb_release -cs)-pgdg main" > /etc/apt/sources.list.d/pgdg.list'
sudo apt update

# Install PostgreSQL versions
echo -e "${YELLOW}[3/3] Installing PostgreSQL...${NC}"
for version in "${VERSION_ARRAY[@]}"; do
    version=$(echo "$version" | xargs) # Trim whitespace
    echo "Installing PostgreSQL $version ($PACKAGE_TYPE)..."
    
    PACKAGES=""
    [ "$INSTALL_CLIENT" = true ] && PACKAGES="$PACKAGES postgresql-client-$version"
    [ "$INSTALL_SERVER" = true ] && PACKAGES="$PACKAGES postgresql-$version"
    
    if [ -n "$PACKAGES" ]; then
        sudo apt install -y $PACKAGES
    fi
done

echo -e "${GREEN}✓ PostgreSQL installation completed successfully!${NC}"
echo ""
echo "Installation Summary:"
echo "  Versions: $VERSIONS"
echo "  Packages: $PACKAGE_TYPE"
echo ""
echo "Verification:"

if [ "$INSTALL_CLIENT" = true ]; then
    echo "  Client version: $(psql --version 2>/dev/null || echo 'Check with: psql --version')"
fi

if [ "$INSTALL_SERVER" = true ]; then
    echo "  Server status: $(sudo systemctl is-active postgresql 2>/dev/null || echo 'Check with: sudo systemctl status postgresql')"
fi

