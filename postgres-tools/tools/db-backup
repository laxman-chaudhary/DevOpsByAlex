#!/bin/bash

# Define colors for terminal output
GREEN="\033[0;32m"
YELLOW="\033[1;33m"
RED="\033[0;31m"
BLUE="\033[0;34m"
CYAN="\033[0;36m"
BOLD="\033[1m"
NC="\033[0m" # No Color

# Get parent directory (postgres-tools) where .env is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="$(dirname "$SCRIPT_DIR")/.env"

# Load environment variables
if [ -f "$ENV_FILE" ]; then
    export $(grep -v '^#' "$ENV_FILE" | xargs)
else
    echo "❌ Error: .env file not found at $ENV_FILE"
    exit 1
fi

# Check required variables
if [[ -z "$DB_HOST" || -z "$DB_PORT" || -z "$POSTGRES_USER" || -z "$POSTGRES_PASSWORD" || -z "$BACKUP_DIR" || -z "$REPORT_FILE" || -z "$RETENTION_POLICY" ]]; then
    echo "❌ Error: Missing required environment variables!"
    exit 1
fi

# Ensure backup directory exists
mkdir -p "$BACKUP_DIR"

# Fetch Public IPv4
IP_ADDRESS=$(curl -s ifconfig.me)

# Get start time
DATESTAMP=$(date +"%Y-%b-%d")
TIMESTAMP=$(date +"%I:%M:%S %p")
START_TIME=$(date +%s)

echo -e "\n📦 ${CYAN}Starting database backups...${NC}"
echo -e "📅 Date: ${BOLD}$DATESTAMP${NC} | ⏰ Started at: ${BOLD}$TIMESTAMP${NC}\n"

# Generate HTML Report
echo "<!DOCTYPE html>
<html>
<head>
    <meta charset='UTF-8'>
    <title>📦 Database Backup Report</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; padding: 20px; text-align: center; }
        .container { max-width: 700px; background: #fff; padding: 20px; border-radius: 10px; box-shadow: 0px 4px 10px rgba(0, 0, 0, 0.1); margin: auto; }
        h2 { color: #333; }
        .info { text-align: left; padding: 10px; border-radius: 5px; margin: 10px 0; background: #f9f9f9; border-left: 5px solid #3498db; }
        .success { color: #2ecc71; font-weight: bold; }
        .error { color: #e74c3c; font-weight: bold; }
        .footer { margin-top: 20px; font-size: 14px; color: #666; text-align: left; }
        .signature { border-top: 1px solid #ddd; padding-top: 15px; margin-top: 20px; text-align: left; font-size: 14px; color: #333; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; border: 1px solid #ddd; text-align: left; }
        th { background-color: #f4a261; color: white; }
        td.success { color: #2ecc71; font-weight: bold; }
    </style>
</head>
<body>
<div class='container'>
    <h2>📦 Database Backup Report</h2>
    <p><strong>📅 Date:</strong> $DATESTAMP | <strong>⏰ Started at:</strong> $TIMESTAMP</p>
    <p><strong>🏢 Hostname:</strong> $(hostname) | 🌐 <strong>Public IP:</strong> $IP_ADDRESS</p>
    <p><strong>📜 Retention Period:</strong> $RETENTION_POLICY days</p>" > "$REPORT_FILE"

# List databases (ignoring system databases)
IGNORE_LIST=("template0" "template1")
IGNORE_SQL=$(printf "'%s'," "${IGNORE_LIST[@]}")
IGNORE_SQL=${IGNORE_SQL%,}

DATABASES=$(PGPASSWORD=$POSTGRES_PASSWORD psql -h $DB_HOST -p $DB_PORT -U $POSTGRES_USER -d postgres -t -c "SELECT datname FROM pg_database WHERE datname NOT IN ($IGNORE_SQL);" | awk '{$1=$1};1')

if [[ -z "$DATABASES" ]]; then
    echo "❌ No user-created databases found!"
    echo "<p style='color:red;'>❌ No databases found to backup!</p>" >> "$REPORT_FILE"
    exit 1
fi

# Show list of databases and ask for selection
mapfile -t DB_LIST < <(echo "$DATABASES")
echo -e "${CYAN}📂 Available PostgreSQL Databases:${NC}"
for i in "${!DB_LIST[@]}"; do
    echo -e "  ${GREEN}[${i}]${NC} ${DB_LIST[$i]}"
done
echo -e "  ${GREEN}[${#DB_LIST[@]}]${NC} Backup ALL databases"
echo ""

# Ask user to select database(s) to backup
echo -ne "${BLUE}📌 Select database to backup [0-${#DB_LIST[@]}] or press Enter for all: ${NC}"
read -r DB_CHOICE

# Handle user input
if [[ -z "$DB_CHOICE" ]]; then
    # If empty, backup all
    SELECTED_DBS=("${DB_LIST[@]}")
    DB_CHOICE_TEXT="all databases"
elif [[ "$DB_CHOICE" == "${#DB_LIST[@]}" ]]; then
    # If user selects "all"
    SELECTED_DBS=("${DB_LIST[@]}")
    DB_CHOICE_TEXT="all databases"
elif [[ "$DB_CHOICE" =~ ^[0-9]+$ ]] && [[ "$DB_CHOICE" -ge 0 ]] && [[ "$DB_CHOICE" -lt "${#DB_LIST[@]}" ]]; then
    # If user selects a specific database
    SELECTED_DBS=("${DB_LIST[$DB_CHOICE]}")
    DB_CHOICE_TEXT="${DB_LIST[$DB_CHOICE]}"
else
    echo -e "${RED}❌ Invalid selection!${NC}"
    exit 1
fi

echo -e "${GREEN}✅ Selected: $DB_CHOICE_TEXT${NC}\n"

# Backup selected database(s)
for DB in "${SELECTED_DBS[@]}"; do
    DB_START_TIME=$(date +%s)
    FILE_NAME="${DB}_backup_${DATESTAMP}_$(date +"%I-%M-%p").sql"
    BACKUP_FILE="${BACKUP_DIR}/${FILE_NAME}"

    echo "🔄 Backing up database: $DB"

    if ! PGPASSWORD=$POSTGRES_PASSWORD pg_dump -h $DB_HOST -p $DB_PORT -U $POSTGRES_USER -d "$DB" -F p -b -f "$BACKUP_FILE" 2>${BACKUP_DIR}/error.log; then
        echo "❌ Backup failed for database: $DB"
        continue
    fi

    DB_END_TIME=$(date +%s)
    DURATION=$((DB_END_TIME - DB_START_TIME))
    BACKUP_SIZE=$(du -h "$BACKUP_FILE" | cut -f1)
done

END_TIME=$(date +%s)
TOTAL_DURATION=$((END_TIME - START_TIME))
FINISH_TIME=$(date +"%I:%M:%S %p")

# **Print completion time in the console**
echo -e "🎉 ${GREEN}All backups completed successfully!${NC}"
echo -e "⏰ Finished at: ${BOLD}$FINISH_TIME${NC} | 🕒 Total time: ${BOLD}$TOTAL_DURATION seconds${NC}\n"

# **Add the same to HTML report**
echo "<p><strong>⏰ Finished at:</strong> $FINISH_TIME | 🕒 <strong>Total time:</strong> $TOTAL_DURATION seconds</p>" >> "$REPORT_FILE"

# Append backup details
echo "<h3>📂 <strong>Backup Details</strong></h3>
    <table>
        <tr>
            <th>Database</th>
            <th>Duration</th>
            <th>Backup Size</th>
            <th>Status</th>
        </tr>" >> "$REPORT_FILE"

echo "<tr><td>$DB</td><td>$DURATION sec</td><td>$BACKUP_SIZE</td><td class='success'>Success</td></tr>" >> "$REPORT_FILE"

echo "</table>" >> "$REPORT_FILE"

# Run cleanup after backup
echo "🧹 Cleaning up old backups..."
find "$BACKUP_DIR" -type f -name "*.sql" -mtime +$RETENTION_POLICY -exec rm -f {} \;
echo "✅ Cleanup completed."

# **Restore the Signature Section**
echo "<div class='signature'>
        <h3>About Me</h3>
        <p><strong>Did you know?</strong> I specialize in infrastructure automation and CI/CD pipelines. Learn more on my <a href='https://www.laxmanchaudhary.com' target='_blank'>website</a>.</p>
        <p><strong>About Me:</strong> I'm a DevOps engineer with 7+ years of IT experience, skilled in DevOps, cloud computing, and security.</p>
        <p><strong>Best Regards,</strong><br><strong>Alex</strong><br>🌍 <a href='https://www.laxmanchaudhary.com' target='_blank'>www.laxmanchaudhary.com</a><br>
        🔗 <a href='https://www.linkedin.com/in/laxman-chaudhary/' target='_blank'>Connect on LinkedIn</a></p>
    </div>" >> "$REPORT_FILE"

echo "</div></body></html>" >> "$REPORT_FILE"

