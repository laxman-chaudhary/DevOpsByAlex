#!/bin/bash

# PostgreSQL Manager - Master Script
# Bundles all PostgreSQL management tools in one place

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOLS_DIR="$SCRIPT_DIR/tools"

# Function to display main menu
show_menu() {
    clear
    echo -e "${CYAN}${BOLD}╔════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}${BOLD}║   PostgreSQL Management Suite          ║${NC}"
    echo -e "${CYAN}${BOLD}╚════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}📦 INSTALLATION:${NC}"
    echo -e "  ${GREEN}1${NC}) Install PostgreSQL"
    echo ""
    echo -e "${YELLOW}🗄️  DATABASE MANAGEMENT:${NC}"
    echo -e "  ${GREEN}2${NC}) Create Database & User"
    echo -e "  ${GREEN}3${NC}) List Databases"
    echo ""
    echo -e "${YELLOW}💾 BACKUP & RESTORE:${NC}"
    echo -e "  ${GREEN}4${NC}) Backup Database"
    echo -e "  ${GREEN}5${NC}) Restore Database"
    echo ""
    echo -e "${YELLOW}📧 REPORTING:${NC}"
    echo -e "  ${GREEN}6${NC}) Send Backup Report"
    echo ""
    echo -e "${RED}0${NC}) Exit"
    echo ""
}

# Function to validate script exists
validate_script() {
    if [ ! -f "$1" ]; then
        echo -e "${RED}❌ Error: Script not found at $1${NC}"
        exit 1
    fi
    if [ ! -x "$1" ]; then
        chmod +x "$1"
    fi
}

# Function to run a script
run_script() {
    local script_path="$1"
    local script_name=$(basename "$script_path")
    
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${BOLD}Running: $script_name${NC}"
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    
    validate_script "$script_path"
    
    # Pass any arguments to the script
    if [ $# -gt 1 ]; then
        "$script_path" "${@:2}"
    else
        "$script_path"
    fi
    
    echo ""
    echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}✓ Script completed${NC}"
    echo ""
    read -p "Press Enter to return to menu..."
}

# Main loop
while true; do
    show_menu
    read -p "Select an option [0-6]: " choice
    
    case $choice in
        1)
            # Install PostgreSQL
            read -p "Enter PostgreSQL version(s) [16,17,18 or press Enter for interactive]: " versions
            if [ -z "$versions" ]; then
                run_script "$SCRIPT_DIR/postgres-install"
            else
                run_script "$SCRIPT_DIR/postgres-install" "$versions"
            fi
            ;;
        2)
            # Create Database & User
            run_script "$SCRIPT_DIR/pg-provision"
            ;;
        3)
            # List Databases
            run_script "$TOOLS_DIR/db-list"
            ;;
        4)
            # Backup Database
            run_script "$TOOLS_DIR/db-backup"
            ;;
        5)
            # Restore Database
            run_script "$TOOLS_DIR/db-restore"
            ;;
        6)
            # Send Backup Report
            run_script "$TOOLS_DIR/backup-report"
            ;;
        0)
            echo -e "${GREEN}👋 Goodbye!${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}❌ Invalid option. Please try again.${NC}"
            sleep 2
            ;;
    esac
done
