#!/bin/bash

set -euo pipefail

# Ensure script runs in non-interactive mode
export DEBIAN_FRONTEND=noninteractive

PHP_VERSION="${1:-8.3}"

if [[ "$PHP_VERSION" != "8.3" && "$PHP_VERSION" != "8.4" ]]; then
  echo "❌ Unsupported PHP version: $PHP_VERSION"
  echo "Usage: $0 [8.3|8.4]"
  exit 1
fi

if [[ -r /etc/os-release ]]; then
  # shellcheck disable=SC1091
  source /etc/os-release
  if [[ "${ID:-}" != "ubuntu" ]]; then
    echo "⚠️ This script is tuned for Ubuntu. Detected: ${ID:-unknown}"
  fi
fi

echo "🚀 Starting PHP ${PHP_VERSION} setup on Ubuntu..."

echo "🔄 [1/8] Updating package index..."
sudo apt-get update -qq

echo "📦 [2/8] Installing base dependencies..."
sudo apt-get install -yqq --no-install-recommends \
  software-properties-common \
  apt-transport-https \
  ca-certificates \
  lsb-release \
  curl \
  gnupg2

if ! grep -Rqs "^deb .*ondrej/php" /etc/apt/sources.list /etc/apt/sources.list.d/ 2>/dev/null; then
  echo "🧩 [3/8] Adding Ondrej PHP PPA..."
  sudo add-apt-repository -y ppa:ondrej/php
else
  echo "✅ [3/8] Ondrej PHP PPA already configured."
fi

echo "🔄 [4/8] Refreshing package index after repository setup..."
sudo apt-get update -qq

echo "🐘 [5/8] Installing Apache, PHP ${PHP_VERSION}, and extensions..."
sudo apt-get install -yqq --no-install-recommends \
  apache2 \
  libapache2-mod-fcgid \
  php${PHP_VERSION} \
  php${PHP_VERSION}-cli \
  php${PHP_VERSION}-common \
  php${PHP_VERSION}-fpm \
  php${PHP_VERSION}-curl \
  php${PHP_VERSION}-mysql \
  php${PHP_VERSION}-xml \
  php${PHP_VERSION}-mbstring \
  php${PHP_VERSION}-zip \
  php${PHP_VERSION}-bcmath \
  php${PHP_VERSION}-gd \
  php${PHP_VERSION}-intl \
  php${PHP_VERSION}-imap \
  php${PHP_VERSION}-opcache \
  php-imagick \
  php-ssh2

echo "🧰 [6/8] Enabling Apache modules and PHP-FPM config..."
sudo a2enmod proxy_fcgi setenvif rewrite headers ssl >/dev/null
sudo a2enconf "php${PHP_VERSION}-fpm" >/dev/null

if sudo a2query -m "php${PHP_VERSION}" >/dev/null 2>&1; then
  sudo a2dismod "php${PHP_VERSION}" >/dev/null || true
fi

echo "🔧 [7/8] Enabling and restarting services..."
sudo systemctl enable --now "php${PHP_VERSION}-fpm"
sudo systemctl enable --now apache2
sudo systemctl restart "php${PHP_VERSION}-fpm"
sudo systemctl restart apache2

echo "🧪 [8/8] Verifying installation..."
echo "✅ PHP CLI: $(php -v | head -n 1)"
echo "✅ Apache:  $(apache2 -v | head -n 1)"
echo "✅ PHP-FPM service: $(systemctl is-active php${PHP_VERSION}-fpm)"
echo "✅ Apache service:  $(systemctl is-active apache2)"

echo ""
echo "🎉 PHP ${PHP_VERSION} setup complete!"
echo "🌐 Apache is running. Place your app in /var/www/html or your vhost path."
